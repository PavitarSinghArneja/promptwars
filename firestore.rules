rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // triageReports: authenticated users can only read/write their own records
    match /triageReports/{reportId} {
      allow read, delete: if request.auth != null && resource.data.responderId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.responderId == request.auth.uid
                    && request.resource.data.keys().hasAll(['triageLevel', 'summary', 'processedAt', 'responderId']);
      // No update — triage reports are immutable once created
      allow update: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
